{
  "name": "cadmus",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "pnpm -r run build",
    "test": "pnpm -r run test",
    "typecheck": "pnpm -r run typecheck",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "dev": "concurrently -n infra,server,sidecar,web -c blue,green,yellow,magenta \"pnpm dev:infra\" \"pnpm dev:server\" \"pnpm dev:sidecar\" \"pnpm dev:web\"",
    "dev:infra": "docker compose up db localstack",
    "dev:server": "cd packages/server && cargo run",
    "dev:sidecar": "pnpm -F @cadmus/sidecar dev",
    "dev:web": "pnpm -F @cadmus/web dev",
    "build:web": "pnpm -F @cadmus/web build"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.4",
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "concurrently": "^9.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "prettier": "^3.0.0",
    "typescript-eslint": "^8.0.0"
  }
}
