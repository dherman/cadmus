# Cadmus Development Environment
# Copy to .env and adjust as needed. All values below are the defaults.

# --- Infrastructure (Docker) ---
# Postgres is exposed on host port 5433 to avoid conflicts with local installs.
POSTGRES_DB=cadmus
POSTGRES_PASSWORD=postgres

# --- Rust Server (packages/server) ---
DATABASE_URL=postgres://postgres:postgres@localhost:5433/cadmus
S3_ENDPOINT=http://localhost:4566
S3_BUCKET=cadmus-documents
JWT_SECRET=dev-secret-change-in-production
SIDECAR_URL=http://localhost:3001
PORT=8080
RUST_LOG=info

# --- Web Client (packages/web) ---
VITE_API_URL=http://localhost:8080
VITE_WS_URL=ws://localhost:8080/api/docs
